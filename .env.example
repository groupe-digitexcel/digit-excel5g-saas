# ================================================
# DIGIT-EXCEL5G SAAS v3.1 — Environment Variables
# Copy to .env.local for development
# Add to Vercel dashboard for production
# ================================================

# ── SUPABASE (get from supabase.com project settings) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AI PROVIDERS ──
REPLICATE_API_KEY=r8_your_replicate_key
OPENROUTER_API_KEY=sk-or-your_openrouter_key
GEMINI_API_KEY=your_gemini_key

# ── HYPERFRAMES (Video Generation) ──
# HyperFrames uses Node.js >= 22 + FFmpeg
# Install: npx hyperframes init (installs globally)
# On Vercel: add to build command: npm install && npx hyperframes doctor
# FFmpeg on Vercel: use @vercel/ffmpeg or install via postinstall
HYPERFRAMES_ENABLED=true

# ── PAYMENTS (Cameroon) ──
MTN_MOMO_NUMBER=+237600000000
ORANGE_MONEY_NUMBER=+237690000000

# ── APP ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
